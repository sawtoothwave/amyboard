        <mxCell id="iQbmUIqxEd2zn6_iVgKn-64" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Display modes&lt;/h1&gt;&lt;p&gt;The selected display mode (default: blank) should activate and take over the screen after 10 seconds of encoder idleness. Turning or clicking the encoder while the display mode is active should turn the screen back on and return the user to whatever the most recent pre-idle state was.&lt;/p&gt;&lt;p&gt;Selecting a display mode from the display mode list should immediately activate the display mode, without waiting for the idle timeout.&lt;/p&gt;" vertex="1">
          <mxGeometry height="230" width="180" x="1130" y="740" as="geometry" />
        </mxCell>
        <mxCell id="IMcBSlxd4zTTgSHxiomu-6" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" value="display current sketch&#39;s menu" vertex="1">
          <mxGeometry height="50" width="180" x="960" y="230" as="geometry" />
        </mxCell>
        <mxCell id="IMcBSlxd4zTTgSHxiomu-11" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" value="display &quot;no menu&quot;" vertex="1">
          <mxGeometry height="50" width="180" x="970" y="340" as="geometry" />
        </mxCell>
        <mxCell id="IMcBSlxd4zTTgSHxiomu-14" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Hold to exit&lt;/h1&gt;&lt;p&gt;Long-pressing the encoder rather than just clicking it should always go backwards/up one menu level. For example, if the user is looking at the list of display modes, long-pressing the encoder should bring them back to the global wrapper menu. If they&#39;re paging through the list of sketches, a long-press on the encoder should bring them back to the global wrapper menu.&lt;/p&gt;" vertex="1">
          <mxGeometry height="230" width="180" x="90" y="620" as="geometry" />
        </mxCell>
